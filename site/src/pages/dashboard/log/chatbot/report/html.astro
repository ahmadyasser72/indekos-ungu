---
import { formatDate } from "@indekos/utilities/date";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	chatbotQuerySchema,
	DIRECTION_LABELS,
	fetchChatbotLogs,
	formatMessageMarkdown,
	getChatbotStats,
} from "../_data";

const params = Astro.locals.parseQuery(chatbotQuerySchema);

const chatbotLogs = await fetchChatbotLogs(params);
const chatbotStats = getChatbotStats(chatbotLogs);

const filterParts: string[] = [];
if (params.direction) {
	filterParts.push(`Arah: ${DIRECTION_LABELS[params.direction]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}

const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Percakapan Chatbot" subtitle={subtitle}>
	<div class="mb-6 grid grid-cols-3 gap-4">
		<div class="border border-black p-3">
			<div class="mb-1 text-[10px] font-bold tracking-[0.5px] uppercase">
				Total Percakapan
			</div>
			<div class="text-lg font-bold">{chatbotStats[0].value}</div>
		</div>
		<div class="border border-black p-3">
			<div class="mb-1 text-[10px] font-bold tracking-[0.5px] uppercase">
				Pesan Masuk
			</div>
			<div class="text-lg font-bold">{chatbotStats[1].value}</div>
			<div class="mt-0.5 text-[11px]">{chatbotStats[1].desc}</div>
		</div>
		<div class="border border-black p-3">
			<div class="mb-1 text-[10px] font-bold tracking-[0.5px] uppercase">
				Pesan Keluar
			</div>
			<div class="text-lg font-bold">{chatbotStats[2].value}</div>
			<div class="mt-0.5 text-[11px]">{chatbotStats[2].desc}</div>
		</div>
	</div>

	<table>
		<thead>
			<tr>
				<th class="w-[18%]">Terkirim</th>
				<th class="w-[18%]">Penghuni</th>
				<th class="w-[10%]">Kamar</th>
				<th class="w-[10%]">Arah</th>
				<th class="w-[44%]">Isi Pesan</th>
			</tr>
		</thead>
		<tbody>
			{
				chatbotLogs.map((row) => (
					<tr>
						<td class="font-mono text-[10px] whitespace-nowrap">
							{formatDate(row.sentAt, "DD MMM YYYY HH:mm")}
						</td>
						<td class="font-semibold">{row.tenantName}</td>
						<td class="text-center font-mono">{row.roomNumber}</td>
						<td class="text-center">{DIRECTION_LABELS[row.direction]}</td>
						<td
							class="max-w-75"
							set:html={formatMessageMarkdown(row.message).split("<br>")[0]}
						/>
					</tr>
				))
			}
		</tbody>
	</table>
</ReportLayout>
