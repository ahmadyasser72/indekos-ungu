---
import { db } from "@indekos/database";
import { formatDate } from "@indekos/utilities/date";

import { render } from "@croct/md-lite";

import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";
import { DIRECTION_LABELS } from "../../_data";

export const partial = true;

const log = await db.query.chatbotMessages.findFirst({
	where: { id: Number(Astro.params.id) },
	with: {
		tenant: {
			with: {
				lease: { with: { room: true } },
			},
		},
	},
});

const [chatbotLog, message] = log
	? [
			{
				...log,
				tenantName: log.tenant.fullName,
				roomNumber: log.tenant.lease?.room?.roomNumber ?? "-",
			},
			render(log.message, {
				fragment: (node) =>
					node.children
						.join("")
						.replaceAll("\n", "<br>")
						.split("<br>")
						.filter(Boolean)
						.join("<br>"),
				text: (node) => node.content,
				bold: (node) => `<b>${node.children}</b>`,
				italic: (node) => `<b>${node.children}</b>`,
				strike: (node) => `<s>${node.children}</s>`,
				code: (node) => `<code>${node.content}</code>`,
				link: (node) => `<a href="${node.href}">${node.children}</a>`,
				image: (node) => `<p>[gambar ${node.alt}]</p>`,
				paragraph: (node) => `<p>${node.children.join("")}</p><br>`,
			}),
		]
	: [];

if (!log) Astro.response.status = 404;
---

<Modal
	id="view_message"
	title="Detail Pesan Chatbot"
	icon="lucide:message-square-text"
>
	{
		chatbotLog ? (
			<>
				<div class="grid grid-cols-2 gap-2 border-b border-base-200 pb-4 text-sm">
					<span class="font-bold">Penghuni:</span>
					<span>
						{chatbotLog.tenantName} (Kamar {chatbotLog.roomNumber})
					</span>
					<span class="font-bold">Arah:</span>
					<span>{DIRECTION_LABELS[chatbotLog.direction]}</span>
					<span class="font-bold">Terkirim:</span>
					<span>{formatDate(chatbotLog.sentAt, "DD MMM YYYY HH:mm:ss")}</span>
				</div>

				<div class="mt-4 text-sm">
					<span class="mb-1 block font-bold">Isi Pesan:</span>
					<div
						class="max-h-96 overflow-y-auto rounded border border-base-300 bg-base-200 p-4 text-sm leading-relaxed"
						set:html={message}
					/>
				</div>
			</>
		) : (
			<NotFound label="Chatbot Log" />
		)
	}
</Modal>
