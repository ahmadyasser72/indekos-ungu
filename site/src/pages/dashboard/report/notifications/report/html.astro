---
import { formatDate } from "@indekos/utilities/date";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	fetchNotifications,
	getNotificationStats,
	NOTIFICATION_STATUS_LABELS,
	NOTIFICATION_TYPE_LABELS,
	notificationQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(
	notificationQuerySchema.omit({ query: true }),
);

const notifications = await fetchNotifications(params);
const notificationStats = getNotificationStats(notifications);

const filterParts: string[] = [];
if (params.type) {
	filterParts.push(`Jenis: ${NOTIFICATION_TYPE_LABELS[params.type]}`);
}
if (params.status) {
	filterParts.push(`Status: ${NOTIFICATION_STATUS_LABELS[params.status]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Riwayat Notifikasi" subtitle={subtitle}>
	<div class="mb-6 grid grid-cols-3 gap-4">
		<div class="border border-black p-3">
			<div class="mb-1 text-[10px] font-bold tracking-[0.5px] uppercase">
				Total Notifikasi
			</div>
			<div class="text-lg font-bold">{notificationStats[0].value}</div>
		</div>
		<div class="border border-black p-3">
			<div class="mb-1 text-[10px] font-bold tracking-[0.5px] uppercase">
				Terkirim
			</div>
			<div class="text-lg font-bold">{notificationStats[1].value}</div>
			<div class="mt-0.5 text-[11px]">{notificationStats[1].desc}</div>
		</div>
		<div class="border border-black p-3">
			<div class="mb-1 text-[10px] font-bold tracking-[0.5px] uppercase">
				Pending & Gagal
			</div>
			<div class="text-lg font-bold">{notificationStats[2].value}</div>
			<div class="mt-0.5 text-[11px]">{notificationStats[2].desc}</div>
		</div>
	</div>

	<table>
		<thead>
			<tr>
				<th class="w-[18%]">Dibuat</th>
				<th class="w-[18%]">Dikirim</th>
				<th class="w-[22%]">Penghuni</th>
				<th class="w-[14%]">No. Invoice</th>
				<th class="w-[14%]">Jenis</th>
				<th class="w-[14%]">Status</th>
			</tr>
		</thead>
		<tbody>
			{
				notifications.map(
					({
						createdAt,
						sentAt,
						tenantName,
						roomNumber,
						invoiceNumber,
						type,
						status,
					}) => (
						<tr>
							<td class="font-mono text-[10px]">
								{formatDate(createdAt, "DD MMM YYYY HH:mm")}
							</td>
							<td class="font-mono text-[10px]">
								{sentAt ? formatDate(sentAt, "DD MMM YYYY HH:mm") : "-"}
							</td>
							<td>
								{tenantName}
								<span class="ml-1 font-mono text-[10px] opacity-60">
									({roomNumber})
								</span>
							</td>
							<td class="font-mono font-semibold">{invoiceNumber}</td>
							<td>{NOTIFICATION_TYPE_LABELS[type]}</td>
							<td class="font-semibold">
								{NOTIFICATION_STATUS_LABELS[status]}
							</td>
						</tr>
					),
				)
			}
		</tbody>
		<tfoot>
			<tr>
				<td class="border border-black bg-gray-100 p-2 font-bold" colspan="6">
					Total notifikasi: {notifications.length}
				</td>
			</tr>
		</tfoot>
	</table>
</ReportLayout>
