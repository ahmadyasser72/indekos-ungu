---
import { db } from "@indekos/database";

import { actions } from "astro:actions";

import FormField from "~/components/form/form-field.astro";
import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";
import { endDateCalendar, type CalendarData } from "../_lease-calendar-helpers";

export const partial = true;

const tenant = await db.query.tenants.findFirst({
	columns: { id: true, fullName: true },
	with: {
		lease: {
			columns: { startDate: true },
		},
	},
	where: { id: Number(Astro.params.id) },
});

if (!tenant) Astro.response.status = 404;

const endDateCalendarData: CalendarData = tenant?.lease?.startDate
	? endDateCalendar(tenant.lease.startDate, { disablePast: false })
	: { enabled: [] };
---

<Modal
	id="terminate_lease"
	title="Akhiri Sewa"
	icon="lucide:user-x"
	iconClass="text-error"
>
	{
		tenant ? (
			<>
				<p class="mb-4 text-sm text-base-content/70">
					Apakah Anda yakin ingin menandai penghuni{" "}
					<strong>{tenant.fullName}</strong> telah keluar? Kontrak sewa aktif
					mereka akan diakhiri hari ini dan kamar yang bersangkutan akan kembali
					kosong/tersedia.
				</p>

				<ModalForm
					action={actions.manage.tenants.terminate}
					modalId="terminate_lease"
					submitClass="btn-error"
					submitLabel="Konfirmasi Akhiri"
					target="#form_result, #tenants-content-wrapper"
				>
					<input name="id" type="hidden" value={tenant.id} />

					<FormField label="Tanggal Selesai">
						<div
							class="end-period vc w-full"
							data-calendar={JSON.stringify(endDateCalendarData)}
						/>
						<input class="input w-full" name="end_date" type="text" readonly />
					</FormField>
				</ModalForm>
			</>
		) : (
			<NotFound label="Penghuni" />
		)
	}
</Modal>

<script>
	import { initCalendar } from "../_lease-calendar";

	initCalendar({
		selector: ".end-period",
		onClickDate: ({ calendar, date }) => {
			const input = calendar.nextElementSibling as HTMLInputElement;
			input.value = date ?? "";
			input.dispatchEvent(new Event("input"));
		},
	});
</script>
