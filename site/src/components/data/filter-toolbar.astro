---
import { formatPeriod } from "@indekos/utilities/date";

import Icon from "~/components/ui/icon.astro";

interface Props {
	name: string;
	from?: Date;
	to?: Date;
}

const { name, from, to } = Astro.props;
const filterClass = `filter-${name}`;
const targetId = `#${name}-content-wrapper`;
---

<div class="card border border-base-300 bg-base-100 shadow-sm">
	<div
		class="card-body gap-3 p-4 sm:flex-row sm:items-center sm:justify-between"
		hx-include={`.${filterClass}`}
		hx-select={targetId}
		hx-swap="outerHTML transition:true"
		hx-target={targetId}
	>
		{
			from && to && (
				<div
					class="flex w-full items-center gap-3 sm:flex-1"
					id="filter-period"
					hx-select-oob="#filter-period"
				>
					<Icon
						class="shrink-0 text-primary"
						name="lucide:calendar"
						size="size-5"
					/>
					<span class="hidden text-sm font-semibold text-base-content/75 md:inline">
						Pilih Periode:
					</span>
					<input
						hx-get={Astro.url.pathname}
						class={`input input-sm ${filterClass} w-full sm:w-40`}
						name="from"
						type="month"
						value={formatPeriod(from)}
					/>
					<span class="text-sm font-semibold text-base-content/70">
						Sampai:
					</span>
					<input
						hx-get={Astro.url.pathname}
						class={`input input-sm ${filterClass} w-full sm:w-40`}
						name="to"
						type="month"
						value={formatPeriod(to)}
						min={formatPeriod(from)}
					/>
				</div>
			)
		}

		<div class="flex gap-2">
			<slot name="actions" />
		</div>
	</div>
</div>
