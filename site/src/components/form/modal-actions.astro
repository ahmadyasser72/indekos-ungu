---
import IconLoader from "~/components/ui/icon-loader.astro";

interface Props {
	formId: string;
	buttonId: string;
	label?: string;
	submitClass?: string;
	cancelLabel?: string;
}

const {
	formId,
	buttonId,
	label = "Simpan",
	submitClass = "btn-primary",
	cancelLabel = "Batal",
} = Astro.props;
---

<form class="flex gap-2" method="dialog">
	<button class="btn btn-outline btn-sm">{cancelLabel}</button>
	<button
		class={`btn ${submitClass} btn-sm`}
		id={buttonId}
		type="submit"
		form={formId}
	>
		<IconLoader />
		{label}
	</button>
</form>
