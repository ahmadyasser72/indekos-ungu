---
import Icon from "~/components/ui/icon.astro";

const pushActive = !!(await Astro.session?.get("pushEndpoint"));
---

<button
	class="btn btn-square btn-ghost"
	id="notification-popover-button"
	popovertarget="notification-popover"
>
	<Icon
		name={pushActive ? "lucide:bell-ring" : "lucide:bell-off"}
		size="size-5"
	/>
</button>
<ul
	hx-get
	hx-trigger="intersect"
	class="menu dropdown dropdown-end dropdown-bottom mt-2 w-64 menu-sm bg-base-100 p-2 shadow-sm"
	id="notification-popover"
	hx-headers="js:{ 'push-endpoint': localStorage.subscriptionEndpoint ?? '' }"
	hx-select="#notification-popover > li"
	popover
	style="position-anchor:--user-anchor"
>
	<li class="htmx-indicator">
		<button class="btn btn-sm" disabled>
			<Icon name="svg-spinners:90-ring-with-bg" /> Loading
		</button>
	</li>

	<li class="htmx-indicator-replace">
		<button
			id="push-toggle"
			data-active={pushActive}
			class:list={["btn btn-sm", pushActive ? "btn-error" : "btn-primary"]}
		>
			{pushActive ? "Nonaktifkan Notifikasi" : "Aktifkan Notifikasi"}
		</button>
	</li>
	<li class="htmx-indicator-replace">
		<button class="btn btn-sm" id="push-test" disabled={!pushActive}>
			Kirim Test Notifikasi
		</button>
	</li>
</ul>

<script>
	import { actions } from "astro:actions";
	import { VAPID_PUBLIC_KEY } from "astro:env/client";

	const sw = await new Promise<ServiceWorkerRegistration | null>(
		async (resolve) => {
			if ("serviceWorker" in navigator && "PushManager" in window) {
				await navigator.serviceWorker
					.register("/sw.js")
					.catch(() => resolve(null));

				navigator.serviceWorker.ready.then(resolve);
			} else {
				resolve(null);
			}
		},
	);

	htmx.onLoad(async (node) => {
		if (!(node instanceof HTMLElement)) return;

		const pushToggle = node.querySelector<HTMLButtonElement>("#push-toggle");
		const pushTest = node.querySelector<HTMLButtonElement>("#push-test");

		const syncLocalSubscription = (subscription: PushSubscription | null) => {
			if (subscription?.endpoint)
				localStorage.setItem("subscriptionEndpoint", subscription.endpoint);
			else localStorage.removeItem("subscriptionEndpoint");
		};

		if (!sw) {
			syncLocalSubscription(null);
			pushToggle?.addEventListener("click", () => {
				showClientSideToast("error", "Browser tidak mendukung.");
			});

			return;
		}

		if (pushToggle) {
			let subscription = await sw.pushManager.getSubscription();
			syncLocalSubscription(subscription);

			const subscribe = async () => {
				const permission =
					Notification.permission === "default"
						? await Notification.requestPermission()
						: Notification.permission;
				if (permission !== "granted") {
					showClientSideToast("error", "Akses notifikasi ditolak.");
					return;
				}

				subscription = await sw.pushManager.subscribe({
					userVisibleOnly: true,
					applicationServerKey: VAPID_PUBLIC_KEY,
				});

				const { error } = await actions.push.subscribe(
					subscription.toJSON() as never,
				);
				if (error) {
					console.error("Failed to save subscription:", error);
					await subscription.unsubscribe();
					subscription = null;
					showClientSideToast(
						"error",
						"Gagal mendaftarkan notifikasi browser.",
					);
				}
			};

			const unsubscribe = async () => {
				if (!subscription) return;

				const { error } = await actions.push.unsubscribe({
					endpoint: subscription.endpoint,
				});
				if (error) {
					console.error("Failed to remove subscription:", error);
					showClientSideToast("error", "Gagal menghapus notifikasi browser.");
					return;
				}

				await subscription.unsubscribe();
				subscription = null;
			};

			pushToggle.addEventListener("click", async () => {
				pushToggle.disabled = true;

				const subscribed = pushToggle.dataset.active === "true";
				await (subscribed ? unsubscribe : subscribe)();
				syncLocalSubscription(subscription);
				await htmx.ajax("get", document.URL, {
					select: "#notification-popover > li",
					selectOOB: "#notification-popover-button",
					target: "#notification-popover",
					headers: {
						"push-endpoint": localStorage.getItem("subscriptionEndpoint") ?? "",
					},
				});

				pushToggle.disabled = false;
			});
		}

		if (pushTest) {
			pushTest.addEventListener("click", async () => {
				pushTest.disabled = true;

				const { error } = await actions.push.test();
				if (error) {
					console.error("Failed to send test notification:", error.message);
					showClientSideToast("error", "Gagal kirim test notifikasi.");
				} else {
					showClientSideToast("info", "Notifikasi test dikirim!");
				}

				pushTest.disabled = false;
			});
		}
	});
</script>
