---
import Alert from "~/components/ui/alert.astro";
import { checkActionResult, type FormResult } from "~/lib/form-result";

// Auto-detect from action results array — first non-null wins
let result: FormResult = undefined;
if (!result && Astro.locals.actionResults.length > 0) {
	for (const config of Astro.locals.actionResults) {
		const actionResult = Astro.getActionResult(config.action);
		if (actionResult) {
			result = checkActionResult(actionResult, {
				title: config.title,
				getDescription: config.getDescription,
			});

			break;
		}
	}
}
---

{
	result?.success === false && (
		<Alert id="form_error" type="error" description={result.message} />
	)
}

<div
	class="toast z-10 sm:toast-center"
	id="notification-toasts"
	hx-swap-oob="beforeend:#notification-toasts"
>
	{
		result?.success && (
			<Alert
				type="info"
				title={result.title}
				description={result.description}
			/>
		)
	}

	<Alert
		class="hidden"
		id="alert-client"
		title="title"
		description="description"
	/>
</div>
